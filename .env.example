# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI API Configuration (GitHub Models)
USE_GITHUB_MODELS=True
OPENAI_API_BASE=https://models.inference.ai.azure.com
OPENAI_API_KEY=your_github_token_here
AI_MODEL_NAME=gpt-4o-mini

# Instructions:
# 1. Copy this file to .env.local for local development
# 2. Replace the placeholder values with your actual keys
# 3. In Vercel, add these as Environment Variables in Project Settings
# 4. NEVER commit .env.local to git (it's in .gitignore)
